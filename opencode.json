{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen/qwen2.5-14b": {
          "name": "qwen/qwen2.5-14b"
        }
      }
    }
  },

  "agent" : {
    "custom_plan": {
        "mode": "primary",
        "prompt": "You are a helpful assistant.",
        "tools": {
            "write": false,
            "edit": false,
            "bash": false,
            "glob": false,
            "grep": false,
            "task": false,
            "webfetch": false,
            "todowrite": false,
            "skill": false
        }
    }
  }
}